{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:path:allow-join",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}
