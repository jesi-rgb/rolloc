{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rolloc",
  "version": "0.1.0",
  "identifier": "com.rolloc.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rolloc",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "msi", "nsis", "updater"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3ODQxOUM0MzkxNkVFQkEKUldTNjdoWTV4Qm1FWjVBM3VtZFIxbE96Qk5iZDVpZWMxdW1COWQwbTFJWjhhNnN6YUNuVkRSRisK",
      "endpoints": [
        "https://github.com/jesi-rgb/rolloc/releases/latest/download/latest.json"
      ]
    }
  }
}
